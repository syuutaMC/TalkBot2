FROM python:3.11-slim

WORKDIR /app

# 依存パッケージのインストール
COPY requirements.txt .
RUN pip install --no-cache-dir aiohttp prometheus_client psutil

# アプリケーションファイルのコピー
COPY src/ ./src/

# config ディレクトリは Docker ボリュームでマウント
RUN mkdir -p /app/config

ENV PYTHONUNBUFFERED=1
ENV DASHBOARD_PORT=8080

EXPOSE 8080

CMD ["python", "-u", "src/dashboard.py"]
